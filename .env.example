APP_ENV=development
DATABASE_URL=postgresql+psycopg://spendcontrol:spendcontrol@localhost:5432/spend_control
BACKEND_CORS_ORIGINS=http://localhost:3000

AUTH_MODE=dev-local
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
ENTRA_FRONTEND_CLIENT_ID=
ENTRA_BACKEND_CLIENT_ID=
ENTRA_BACKEND_AUDIENCE=
ENTRA_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
DEV_AUTH_SECRET=dev-only-secret-change-me-1234567890
DEV_AUTH_DEFAULT_EMAIL=developer@local.test
DEV_AUTH_DEFAULT_NAME=Local Developer
DEV_AUTH_DEFAULT_ROLE=admin

AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER_NAME=

LOCAL_UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=10485760

